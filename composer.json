{
  "name": "laravel/laravel",
  "description": "The Laravel Framework.",
  "keywords": [
    "framework",
    "laravel"
  ],
  "license": "MIT",
  "type": "project",
  "require": {
    "php": "^8.3",
    "ext-bcmath": "*",
    "anhskohbo/no-captcha": "^3.8",
    "colorlibhq/adminlte-laravel": "^1.0",
    "denpa/php-bitcoinrpc": "^2.1",
    "intervention/image": "^2.7",
    "laravel/framework": "^13.0",
    "laravel/passport": "^13.0",
    "laravel/tinker": "^3.0",
    "pragmarx/google2fa-laravel": "^3.0",
    "pragmarx/google2fa-qrcode": "^3.0",
    "predis/predis": "^2.3 || ^3.0",
    "rap2hpoutre/laravel-log-viewer": "^3.1"
  },
  "require-dev": {
    "fakerphp/faker": "^1.24",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.8",
    "phpunit/phpunit": "^12.5"
  },
  "autoload": {
    "classmap": [
      "database/seeds",
      "database/factories"
    ],
    "files": [
      "app/Helpers/helpers.php",
      "app/Helpers/corearrays.php",
      "app/Helpers/coreconstants.php"
    ],
    "psr-4": {
      "App\\": "app/",
      "OwenIt\\Auditing\\": "app/Support/Auditing/OwenIt/"
    },
    "exclude-from-classmap": [
      "app/Repositories_old/"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "dont-discover": [
      ]
    }
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate"
    ],
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover"
    ]
  },
  "config": {
    "preferred-install": "dist",
    "sort-packages": true,
    "optimize-autoloader": true,
    "allow-plugins": {
      "kylekatarnls/update-helper": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
